+import org.gradle.internal.impldep.com.fasterxml.jackson.annotation.JsonProperty
+
+class Extension() {
+    @Input
+    var name: String? = null
+
+    @Input
+    var version: String? = null
+
+    @Input
+    var entrypoint: String? = null
+
+    @Input
+    @Optional
