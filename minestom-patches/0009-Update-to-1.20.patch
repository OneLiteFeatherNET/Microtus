+package net.minestom.server.network.packet.client;
+
+import net.minestom.server.network.packet.builder.PacketResponsible;
+import net.minestom.server.network.packet.client.common.*;
+import net.minestom.server.network.packet.client.configuration.ClientFinishConfigurationPacket;
+import net.minestom.server.network.packet.client.login.ClientEncryptionResponsePacket;
+import net.minestom.server.network.packet.client.login.ClientLoginAcknowledgedPacket;
+import net.minestom.server.network.packet.client.login.ClientLoginPluginResponsePacket;
+import net.minestom.server.network.packet.client.login.ClientLoginStartPacket;
+import net.minestom.server.network.packet.client.status.PingPacket;
+import net.minestom.server.network.packet.client.status.StatusRequestPacket;
+import net.minestom.server.network.packet.client.play.*;
+import org.jetbrains.annotations.ApiStatus;
+import org.jetbrains.annotations.NotNull;
+
+@ApiStatus.Experimental
+@ApiStatus.NonExtendable
+@ApiStatus.Internal
+public final class ClientPackets {
+
+    private static final PacketResponsible STATUS_PACKETS;
+    private static final PacketResponsible LOGIN_PACKETS;
+    private static final PacketResponsible CONFIGURATION_PACKETS;
+    private static final PacketResponsible PLAY_PACKETS;
+
+    static {
+        STATUS_PACKETS = PacketResponsible.builder()
+                .packet(StatusRequestPacket::new)
+                .packet(PingPacket::new)
+                .build();
+        LOGIN_PACKETS = PacketResponsible.builder()
+                .packet(ClientLoginStartPacket::new)
+                .packet(ClientEncryptionResponsePacket::new)
+                .packet(ClientLoginPluginResponsePacket::new)
+                .packet(ClientLoginAcknowledgedPacket::new)
+                .build();
+        CONFIGURATION_PACKETS = PacketResponsible.builder()
+                .packet(ClientSettingsPacket::new)
+                .packet(ClientPluginMessagePacket::new)
+                .packet(ClientFinishConfigurationPacket::new)
+                .packet(ClientKeepAlivePacket::new)
+                .packet(ClientPongPacket::new)
+                .packet(ClientResourcePackStatusPacket::new)
+                .build();
+        PLAY_PACKETS = PacketResponsible.builder()
+                .packet(ClientTeleportConfirmPacket::new)
+                .packet(ClientQueryBlockNbtPacket::new)
+                .skip() // difficulty packet
+                .packet(ClientChatAckPacket::new)
+                .packet(ClientCommandChatPacket::new)
+                .packet(ClientChatMessagePacket::new)
+                .packet(ClientChatSessionUpdatePacket::new)
+                .skip() // chunk batch received
+                .packet(ClientStatusPacket::new)
+                .packet(ClientSettingsPacket::new)
+                .packet(ClientTabCompletePacket::new)
+                .packet(ClientConfigurationAckPacket::new)
+                .packet(ClientClickWindowButtonPacket::new)
+                .packet(ClientClickWindowPacket::new)
+                .packet(ClientCloseWindowPacket::new)
+                .packet(ClientWindowSlotStatePacket::new)
+                .packet(ClientPluginMessagePacket::new)
+                .packet(ClientEditBookPacket::new)
+                .packet(ClientQueryEntityNbtPacket::new)
+                .packet(ClientInteractEntityPacket::new)
+                .packet(ClientGenerateStructurePacket::new)
+                .packet(ClientKeepAlivePacket::new)
+                .skip() // lock difficulty
+                .packet(ClientPlayerPositionPacket::new)
+                .packet(ClientPlayerPositionAndRotationPacket::new)
+                .packet(ClientPlayerRotationPacket::new)
+                .packet(ClientPlayerPacket::new)
+                .packet(ClientVehicleMovePacket::new)
+                .packet(ClientSteerBoatPacket::new)
+                .packet(ClientPickItemPacket::new)
+                .skip() // Ping request
+                .packet(ClientCraftRecipeRequest::new)
+                .packet(ClientPlayerAbilitiesPacket::new)
+                .packet(ClientPlayerDiggingPacket::new)
+                .packet(ClientEntityActionPacket::new)
+                .packet(ClientSteerVehiclePacket::new)
+                .packet(ClientPongPacket::new)
+                .packet(ClientSetRecipeBookStatePacket::new)
+                .packet(ClientSetDisplayedRecipePacket::new)
+                .packet(ClientNameItemPacket::new)
+                .packet(ClientResourcePackStatusPacket::new)
+                .packet(ClientAdvancementTabPacket::new)
+                .packet(ClientSelectTradePacket::new)
+                .packet(ClientSetBeaconEffectPacket::new)
+                .packet(ClientHeldItemChangePacket::new)
+                .packet(ClientUpdateCommandBlockPacket::new)
+                .packet(ClientUpdateCommandBlockMinecartPacket::new)
+                .packet(ClientCreativeInventoryActionPacket::new)
+                .skip() // Update Jigsaw Block
+                .packet(ClientUpdateStructureBlockPacket::new)
+                .packet(ClientUpdateSignPacket::new)
+                .packet(ClientAnimationPacket::new)
+                .packet(ClientSpectatePacket::new)
+                .packet(ClientPlayerBlockPlacementPacket::new)
+                .packet(ClientUseItemPacket::new)
+                .build();
+    }
+
+    private ClientPackets() {
+    }
+
+    public static @NotNull PacketResponsible getConfigurationPackets() {
+        return CONFIGURATION_PACKETS;
+    }
+
+    public static @NotNull PacketResponsible getLoginPackets() {
+        return LOGIN_PACKETS;
+    }
+
+    public static @NotNull PacketResponsible getPlayPackets() {
+        return PLAY_PACKETS;
+    }
+
+    public static @NotNull PacketResponsible getStatusPackets() {
+        return STATUS_PACKETS;
+    }
+}
