@@ -0,0 +1,27 @@
+package net.minestom.server.network.packet.server;
+
+import net.minestom.server.network.ConnectionState;
+import org.jetbrains.annotations.NotNull;
+
+public final class ServerStateValidator {
+
+    private ServerStateValidator() { }
+
+    public static boolean validate(ServerPacketState requirements, @NotNull ConnectionState state) {
+        if (requirements == null) {
+            return true;
+        }
+        ConnectionState[] states = requirements.states();
+
+        if (states.length == 1) {
+            return states[0].ordinal() == state.ordinal();
+        }
+
+        boolean hasState = false;
+
+        for (int i = 0; i < states.length && !hasState; i++) {
+            hasState = states[i].ordinal() == state.ordinal();
+        }
+        return hasState;
+    }
+}
