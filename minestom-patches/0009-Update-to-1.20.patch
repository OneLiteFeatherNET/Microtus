diff --git a/src/test/java/net/minestom/server/network/packet/builder/PacketResponsibleTest.java b/src/test/java/net/minestom/server/network/packet/builder/PacketResponsibleTest.java
new file mode 100644
index 0000000000000000000000000000000000000000..4a0b00691e6e36c14fd7294ef2170b8f88f5a52c
--- /dev/null
+++ b/src/test/java/net/minestom/server/network/packet/builder/PacketResponsibleTest.java
@@ -0,0 +1,57 @@
+package net.minestom.server.network.packet.builder;
+
+import net.minestom.server.network.NetworkBuffer;
+import net.minestom.server.network.packet.client.login.ClientLoginAcknowledgedPacket;
+import net.minestom.server.network.packet.client.login.ClientLoginPluginResponsePacket;
+import net.minestom.server.network.packet.client.login.ClientLoginStartPacket;
+import net.minestom.server.network.packet.client.login.EncryptionResponsePacket;
+import org.junit.jupiter.api.Test;
+
+import static org.junit.jupiter.api.Assertions.*;
+
+class PacketResponsibleTest {
+
+    @Test
+    void testUnknownPacket() {
+        PacketResponsible responsible = PacketResponsible.builder().build();
+        int packetId = 10;
+        IllegalStateException exception = assertThrows(
+                IllegalStateException.class, () -> responsible.create(packetId, new NetworkBuffer())
+        );
+
+        assertEquals(IllegalStateException.class, exception.getClass());
+        String expectedMessage = "Packet id 0x0" + Integer.toHexString(packetId) + " isn't registered!";
+        assertEquals(expectedMessage, exception.getMessage());
+    }
+
+    @Test
+    void testPacketRegistration() {
+        var loginPackets = PacketResponsible.builder()
+                .packet(ClientLoginStartPacket::new)
+                .packet(EncryptionResponsePacket::new)
+                .packet(ClientLoginPluginResponsePacket::new)
+                .packet(ClientLoginAcknowledgedPacket::new)
+                .build();
+        assertNotNull(loginPackets);
+        var loginPacket = loginPackets.create(0x00, new NetworkBuffer());
+        assertEquals(ClientLoginStartPacket.class, loginPacket.getClass());
+    }
+
+    @Test
+    void testPacketRegistrationWithSkippedIds() {
+        var loginPackets = PacketResponsible.builder()
+                .packet(ClientLoginStartPacket::new)
+                .skip() // For this test we skip the encryption response packet
+                .packet(ClientLoginPluginResponsePacket::new)
+                .packet(ClientLoginAcknowledgedPacket::new)
+                .build();
+        assertNotNull(loginPackets);
+        IllegalStateException exception = assertThrows(
+                IllegalStateException.class, () -> loginPackets.create(0x01, new NetworkBuffer())
+        );
+        assertEquals(IllegalStateException.class, exception.getClass());
+        String expectedMessage = "Packet id 0x01 isn't registered!";
+        assertEquals(expectedMessage, exception.getMessage());
+    }
+
+}
