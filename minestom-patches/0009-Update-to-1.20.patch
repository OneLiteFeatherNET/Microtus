diff --git a/src/main/java/net/minestom/server/scoreboard/NumberFormat.java b/src/main/java/net/minestom/server/scoreboard/NumberFormat.java
new file mode 100644
index 0000000000000000000000000000000000000000..6d19ebf382b970500782214d9dcd8e290146b1d1
--- /dev/null
+++ b/src/main/java/net/minestom/server/scoreboard/NumberFormat.java
@@ -0,0 +1,85 @@
+package net.minestom.server.scoreboard;
+
+import net.kyori.adventure.text.Component;
+import net.minestom.server.network.NetworkBuffer;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+
+/**
+ * Mojang introduced a change to the score format for scoreboards in the 1.20.3 update a few times ago.
+ * Now, the format has the following options:
+ * - styled: the score  will be displayed with the selected style
+ * - fixed: the score will be displayed with the given component
+ * - blank: the score is not shown
+ * @param component the component
+ * @param formatType the format type
+ */
+public record NumberFormat(
+        @Nullable Component component,
+        @NotNull FormatType formatType
+) implements NetworkBuffer.Writer {
+
+    private NumberFormat() {
+        this(null, FormatType.BLANK);
+    }
+
+    /**
+     * A number format which lets the sidebar scores be blank
+     *
+     * @return the created number format
+     */
+    public static @NotNull NumberFormat asBlank() {
+        return new NumberFormat();
+    }
+
+    /**
+     * A number format which lets the sidebar scores be styled with explicit text
+     *
+     * @param component the styled component
+     * @return the created number format
+     */
+    public static @NotNull NumberFormat asStyled(@NotNull Component component) {
+        return new NumberFormat(component, FormatType.STYLED);
+    }
+
+    /**
+     * A number format which lets the sidebar scores be styled with explicit text
+     *
+     * @param component the fixed component
+     * @return the number format
+     */
+    public static @NotNull NumberFormat asFixed(@NotNull Component component) {
+        return new NumberFormat(component, FormatType.FIXED);
+    }
+
+    /**
+     * Creates a number format from a network buffer
+     *
+     * @param reader the network buffer
+     */
+    public NumberFormat(@NotNull NetworkBuffer reader) {
+        this(reader.readOptional(NetworkBuffer.COMPONENT), FormatType.VALUES[reader.read(NetworkBuffer.VAR_INT)]);
+    }
+
+    /**
+     * Writes the number format to a {@link NetworkBuffer}.
+     * @param writer the {@link NetworkBuffer} reference to accept the data
+     */
+    @Override
+    public void write(@NotNull NetworkBuffer writer) {
+        writer.write(NetworkBuffer.VAR_INT, formatType.ordinal());
+        if (formatType == FormatType.BLANK) return;
+        assert component != null;
+        writer.write(NetworkBuffer.COMPONENT, component);
+    }
+
+    /**
+     * Represents the format options for a player score entry.
+     * For more details see <a href="https://minecraft.wiki/w/Scoreboard#Single_criteria">this page</a>
+     */
+    private enum FormatType {
+        BLANK, STYLED, FIXED;
+
+        static final FormatType[] VALUES = values();
+    }
+}
