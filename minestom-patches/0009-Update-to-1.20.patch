@@ -0,0 +1,59 @@
+package net.minestom.server.network.packet.builder;
+
+import it.unimi.dsi.fastutil.ints.Int2ObjectArrayMap;
+import net.minestom.server.network.NetworkBuffer;
+import net.minestom.server.network.packet.client.ClientPacket;
+import org.jetbrains.annotations.NotNull;
+
+import java.util.function.Function;
+
+/**
+ * The class is the implementation of the {@link PacketResponsible.Builder} interface.
+ * @version 1.0.0
+ * @since 1.2.0
+ */
+public final class PacketResponsibleBuilderImpl implements PacketResponsible.Builder {
+
+    private final Int2ObjectArrayMap<Function<NetworkBuffer, ClientPacket>> packetMap;
+    private int packetId;
+
+    /**
+     * Creates a new instance from the {@link PacketResponsibleBuilderImpl} class.
+     */
+    public PacketResponsibleBuilderImpl() {
+        this.packetMap = new Int2ObjectArrayMap<>();
+        this.packetId = 0;
+    }
+
+    /**
+     * Registers a new packet with the builder instance, assigning a unique packet id.
+     * It is important to ensure correct packet ordering to match ids with the Minecraft protocol.
+     *
+     * @param packetSupplier a supplier that holds information about the packet.
+     * @return the current builder instance.
+     */
+    @Override
+    public PacketResponsible.@NotNull Builder packet(@NotNull Function<NetworkBuffer, ClientPacket> packetSupplier) {
+        this.packetMap.put(packetId++, packetSupplier);
+        return this;
+    }
+
+    /**
+     * Skips the current id without adding a packet to the underlying data structure.
+     * @return the current builder instance
+     */
+    @Override
+    public PacketResponsible.@NotNull Builder skip() {
+        this.packetId++;
+        return this;
+    }
+
+    /**
+     * Builds the {@link PacketResponsible} instance.
+     * @return the created instance
+     */
+    @Override
+    public @NotNull PacketResponsible build() {
+        return new PacketResponsibleImpl(packetMap);
+    }
+}
