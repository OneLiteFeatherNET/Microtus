+package net.minestom.server.entity.metadata.other;
+
+import net.minestom.server.entity.Entity;
+import net.minestom.server.entity.Metadata;
+import net.minestom.server.entity.metadata.PathfinderMobMeta;
+import org.jetbrains.annotations.NotNull;
+
+/**
+ * The metadata implementation contains each additional information which an Allay can have.
+ * @version 1.0.0
+ * @since 1.1.4
+ */
+public class AllayMeta extends PathfinderMobMeta {
+
+    public static final byte OFFSET = PathfinderMobMeta.MAX_OFFSET;
+    public static final byte MAX_OFFSET = OFFSET + 2;
+
+    /**
+     * Creates a new AllayMeta.
+     *
+     * @param entity the entity to apply the metadata to
+     * @param metadata the metadata
+     */
+    public AllayMeta(@NotNull Entity entity, @NotNull Metadata metadata) {
+        super(entity, metadata);
+    }
+
+    /**
+     * Gets the state if an Allay is dancing.
+     * @return true if an Allay is dancing, false otherwise
+     */
+    public boolean isDancing() {
+        return super.metadata.getIndex(OFFSET, false);
+    }
+
+    /**
+     * Sets the state if an Allay is dancing.
+     * @param value the value to set
+     */
+    public void setDancing(boolean value) {
+        super.metadata.setIndex(OFFSET, Metadata.Boolean(value));
+    }
+
+    /**
+     * Gets the state if an Allay can duplicate items.
+     * @return true if an Allay can duplicate items, false otherwise
+     */
+    public boolean canDuplicate() {
+        return super.metadata.getIndex(OFFSET + 1, true);
+    }
+
+    /**
+     * Sets the state if an Allay can duplicate items.
+     * @param value the value to set
+     */
+    public void setCanDuplicate(boolean value) {
+        super.metadata.setIndex(OFFSET + 1, Metadata.Boolean(value));
+    }
+}
