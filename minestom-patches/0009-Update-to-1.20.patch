@@ -0,0 +1,85 @@
+package net.minestom.server.network.packet.builder;
+
+import it.unimi.dsi.fastutil.ints.Int2ObjectArrayMap;
+import net.minestom.server.network.NetworkBuffer;
+import net.minestom.server.network.packet.client.ClientPacket;
+import org.jetbrains.annotations.ApiStatus;
+import org.jetbrains.annotations.Contract;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.UnknownNullability;
+
+import java.util.function.Function;
+
+/**
+ * The idea behind this interface is to reduce the amount of code to build a structure which holds packet references
+ * with specific ids.
+ * @version 1.0.0
+ * @since 1.2.0
+ */
+@ApiStatus.Experimental
+@ApiStatus.Internal
+public sealed interface PacketResponsible permits PacketResponsibleImpl {
+
+    /**
+     * Creates a new reference from the {@link Builder}.
+     * @return the created reference
+     */
+    @Contract(pure = true)
+    static @NotNull PacketResponsible.Builder builder() {
+        return new PacketResponsibleBuilderImpl();
+    }
+
+    /**
+     * Returns the data structure which holds the registered packets for the responsible reference.
+     * @return the underlying data structure
+     */
+    @NotNull Int2ObjectArrayMap<Function<NetworkBuffer, ClientPacket>> packetMap();
+
+    /**
+     * Creates a new {@link ClientPacket} instance from a given packet id.
+     * @param packetId the id from the packet which should be created
+     * @param reader the {@link NetworkBuffer} which holds the packet data
+     * @return the created packet
+     * @throws IllegalStateException if the packet id isn't registered
+     */
+    default @UnknownNullability ClientPacket create(int packetId, @NotNull NetworkBuffer reader) {
+        final Function<NetworkBuffer, ClientPacket> supplier = packetMap().get(packetId);
+        if (supplier == null) {
+            String idHexString = Integer.toHexString(packetId);
+            if (idHexString.length() == 1) {
+                idHexString = "0" + idHexString;
+            }
+            throw new IllegalStateException("Packet id 0x" + idHexString + " isn't registered!");
+
+        }
+        return supplier.apply(reader);
+    }
+
+    /**
+     * The interface defines the method for the {@link Builder}.
+     * An implementation of this interface contains the logic to register packets or skip specific ids
+     * @version 1.0.0
+     * @since 1.2.0
+     */
+    sealed interface Builder permits PacketResponsibleBuilderImpl {
+
+        /**
+         * Can be used to register a new packet.
+         * @param packetSupplier the supplier which holds the information about the packet
+         * @return the current {@link Builder} instance
+         */
+        @NotNull PacketResponsible.Builder packet(@NotNull Function<NetworkBuffer, ClientPacket> packetSupplier);
+
+        /**
+         * Skips the next packet id.
+         * @return the current {@link Builder} instance
+         */
+        @NotNull PacketResponsible.Builder skip();
+
+        /**
+         * Returns a new {@link PacketResponsible} instance from the registered packets.
+         * @return the created {@link PacketResponsible} instance
+         */
+        @NotNull PacketResponsible build();
+    }
+}
