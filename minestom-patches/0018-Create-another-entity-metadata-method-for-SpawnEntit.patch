@@ -2,6 +2,7 @@ package net.minestom.server.listener;
 
 import net.minestom.server.coordinate.Point;
 import net.minestom.server.coordinate.Pos;
+import net.minestom.server.entity.EntityType;
 import net.minestom.server.entity.GameMode;
 import net.minestom.server.entity.Player;
 import net.minestom.server.entity.metadata.PlayerMeta;
@@ -134,7 +135,8 @@ public final class PlayerDiggingListener {
     }
 
     private static void updateItemState(Player player) {
-        PlayerMeta meta = player.getEntityMeta();
+        if (player.getEntityType() != EntityType.PLAYER) return;
+        PlayerMeta meta = player.getPlayerData();
         if (!meta.isHandActive()) return;
         Player.Hand hand = meta.getActiveHand();
 
