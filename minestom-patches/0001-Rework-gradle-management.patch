 }
 
 dependencies {
diff --git a/gradle/libs.versions.toml b/gradle/libs.versions.toml
index b3da234609fcb6f3ab1866a2fc806719b29f97f2..4de407f8a09adb19c1a787f6cc06c2278ce4e0fe 100644
--- a/gradle/libs.versions.toml
+++ b/gradle/libs.versions.toml
@@ -3,29 +3,29 @@ metadata.format.version = "1.1"
 [versions]
 
 # Important dependencies
-adventure = "4.12.0"
-kotlin = "1.7.22"
+adventure = "4.15.0"
+kotlin = "1.9.22"
 hydrazine = "1.7.2"
 dependencyGetter = "v1.0.1"
-minestomData = "ddde11056e"
+data = "1.20-rv1" # Microtus - Use original data generator from minestom
 hephaistos = "2.6.1"
-jetbrainsAnnotations = "23.0.0"
+jetbrainsAnnotations = "24.1.0"
 
 # Terminal / Logging
-tinylog = "2.5.0"
-jline = "3.21.0"
+tinylog = "2.6.2"
+jline = "3.25.1"
 
 # Performance / Data Structures
-caffeine = "3.1.2"
-fastutil = "8.5.9"
+caffeine = "3.1.8"
+fastutil = "8.5.12"
 flare = "2.0.1"
-gson = "2.9.1"
-jcTools = "4.0.1"
+gson = "2.10.1"
+jcTools = "4.0.2"
 
 # Test
-junit-jupiter = "5.8.2"
-junit-platform = "1.8.2"
-mockito = "4.2.0"
+junit-jupiter = "5.10.1"
+junit-platform = "1.10.1"
+mockito = "5.9.0"
 
 # Code Generation
 javaPoet = "1.13.0"
@@ -34,13 +34,13 @@ javaPoet = "1.13.0"
 jNoise = "b93008e35e"
 
 # JMH
-jmh = "1.35"
+jmh = "1.37"
 
 # JCStress
-jcstress = "0.8"
+jcstress = "0.16"
 
 # Gradle plugins
-blossom = "1.3.0"
+blossom = "2.1.0"
 
 [libraries]
 
@@ -59,7 +59,7 @@ kotlin-stdlib-jdk8 = { group = "org.jetbrains.kotlin", name = "kotlin-stdlib-jdk
 # Miscellaneous
 hydrazine = { group = "com.github.MadMartian", name = "hydrazine-path-finding", version.ref = "hydrazine" }
 dependencyGetter = { group = "com.github.Minestom", name = "DependencyGetter", version.ref = "dependencyGetter" }
-minestomData = { group = "com.github.Minestom", name = "MinestomDataGenerator", version.ref = "minestomData" }
+minestomData = { group = "net.minestom", name = "data", version.ref = "data" } # Microtus - Use original data generator from minestom
 jetbrainsAnnotations = { group = "org.jetbrains", name = "annotations", version.ref = "jetbrainsAnnotations" }
 
 # Logging
@@ -110,4 +110,4 @@ terminal = ["jline", "jline-jansi"]
 
 [plugins]
 
-blossom = { id = "net.kyori.blossom", version.ref = "blossom" }
+blossom = { id = "net.kyori.blossom", version.ref = "blossom" }
