From: theEvilReaper <steffenwx@gmail.com>
Date: Sat, 25 Nov 2023 23:54:31 +0100
Subject: [PATCH] Allow cancellation of the PlayerStartSprintingEvent


diff --git a/src/main/java/net/minestom/server/event/player/PlayerStartSprintingEvent.java b/src/main/java/net/minestom/server/event/player/PlayerStartSprintingEvent.java
index c260dfec2e5e2b8efbee3741ddc34a85e21d296f..fc4fda96cb8e876187283cb9f33e54b0b89a01b5 100644
--- a/src/main/java/net/minestom/server/event/player/PlayerStartSprintingEvent.java
+++ b/src/main/java/net/minestom/server/event/player/PlayerStartSprintingEvent.java
@@ -1,22 +1,62 @@
 package net.minestom.server.event.player;
 
 import net.minestom.server.entity.Player;
+import net.minestom.server.event.trait.CancellableEvent;
 import net.minestom.server.event.trait.PlayerInstanceEvent;
 import org.jetbrains.annotations.NotNull;
 
+// Microtus start - Fix incorrect attribute usage for sprinting
+
 /**
- * Called when a player starts sprinting.
+ * - * Called when a player starts sprinting.
+ * The {@link PlayerStartSprintingEvent} is called when a player starts to sprint.
+ * Usually the event is called by the listener which handles the {@link net.minestom.server.network.packet.client.play.ClientEntityActionPacket}.
+ *
+ * @version 1.0.1
+ * @since 1.0.0
  */
-public class PlayerStartSprintingEvent implements PlayerInstanceEvent {
+public class PlayerStartSprintingEvent implements PlayerInstanceEvent, CancellableEvent {
 
     private final Player player;
+    private boolean cancelled;
 
+    /**
+     * Creates a new {@link PlayerStartSprintingEvent} reference.
+     *
+     * @param player the player who is involved
+     */
     public PlayerStartSprintingEvent(@NotNull Player player) {
         this.player = player;
     }
 
+    /**
+     * Sets the cancellation state for the event.
+     *
+     * @param cancelled true if the event should be cancelled, false otherwise
+     */
+    @Override
+    public void setCancelled(boolean cancelled) {
+        this.cancelled = cancelled;
+    }
+
+    /**
+     * Returns the involved player from the event.
+     *
+     * @return the given player
+     */
     @Override
     public @NotNull Player getPlayer() {
         return player;
     }
+
+    /**
+     * Returns whether the event has been cancelled.
+     *
+     * @return true if the event has been cancelled, false otherwise
+     */
+    @Override
+    public boolean isCancelled() {
+        return cancelled;
+    }
 }
+// Microtus stop - Fix incorrect attribute usage for sprinting
diff --git a/src/main/java/net/minestom/server/listener/EntityActionListener.java b/src/main/java/net/minestom/server/listener/EntityActionListener.java
index e4f7405b28c6de7ac854455e292d4b1a6e9768d2..e79ee0ed6439f5348c29739cd87ef23b0ff0e1b7 100644
--- a/src/main/java/net/minestom/server/listener/EntityActionListener.java
+++ b/src/main/java/net/minestom/server/listener/EntityActionListener.java
@@ -4,10 +4,14 @@ import net.minestom.server.entity.Player;
 import net.minestom.server.event.EventDispatcher;
 import net.minestom.server.event.player.*;
 import net.minestom.server.network.packet.client.play.ClientEntityActionPacket;
+import org.jetbrains.annotations.NotNull;
 
-public class EntityActionListener {
+// Microtus start - Fix incorrect attribute usage for sprinting
+public final class EntityActionListener {
 
-    public static void listener(ClientEntityActionPacket packet, Player player) {
+    private EntityActionListener() { }
+
+    public static void listener(@NotNull ClientEntityActionPacket packet, @NotNull Player player) {
         switch (packet.action()) {
             case START_SNEAKING -> EntityActionListener.setSneaking(player, true);
             case STOP_SNEAKING -> EntityActionListener.setSneaking(player, false);
@@ -19,7 +23,7 @@ public class EntityActionListener {
         }
     }
 
-    private static void setSneaking(Player player, boolean sneaking) {
+    private static void setSneaking(@NotNull Player player, boolean sneaking) {
         boolean oldState = player.isSneaking();
 
         player.setSneaking(sneaking);
@@ -33,22 +37,27 @@ public class EntityActionListener {
         }
     }
 
-    private static void setSprinting(Player player, boolean sprinting) {
+    private static void setSprinting(@NotNull Player player, boolean sprinting) {
         boolean oldState = player.isSprinting();
 
         player.setSprinting(sprinting);
 
         if (oldState != sprinting) {
             if (sprinting) {
-                EventDispatcher.call(new PlayerStartSprintingEvent(player));
+                PlayerStartSprintingEvent event = new PlayerStartSprintingEvent(player);
+                EventDispatcher.call(event);
+                if (event.isCancelled()) {
+                    // TODO: Handle property revert
+                }
             } else {
                 EventDispatcher.call(new PlayerStopSprintingEvent(player));
             }
         }
     }
 
-    private static void startFlyingElytra(Player player) {
+    private static void startFlyingElytra(@NotNull Player player) {
         player.setFlyingWithElytra(true);
         EventDispatcher.call(new PlayerStartFlyingWithElytraEvent(player));
     }
 }
+// Microtus stop - Fix incorrect attribute usage for sprinting
\ No newline at end of file
